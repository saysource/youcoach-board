{
  "name": "youcoach-board",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "YouCoach Board — embeddable, backend-free React tactics/drill designer (workspace skeleton).",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "yarn workspace @youcoach-board/core build && yarn workspace @youcoach-board/viewer build && yarn workspace @youcoach-board/designer build",
    "dev": "yarn workspace @youcoach-board/designer dev",
    "dev:trace": "node scripts/dev-trace.mjs",
    "glb": "node scripts/bundle-glbs.mjs",
    "typecheck": "tsc --build --verbose",
    "lint": "eslint .",
    "clean": "rm -rf packages/*/dist packages/*/*.tsbuildinfo"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^7.3.6",
    "vite-plugin-dts": "^4.5.4"
  },
  "packageManager": "yarn@1.9.4"
}
